# GenoTek Global AI Recruitment Pipeline - Environment Variables

# Anthropic API Key (for Claude models)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Gmail Settings
# Gmail sender email address
GMAIL_SENDER_EMAIL=

# Optional: Path to Gmail credentials file
GMAIL_CREDENTIALS_PATH=data/gmail_credentials.json

# Logging Configuration
LOG_LEVEL=INFO

# Optional: OpenAI API Key (alternative to Anthropic)
OPENAI_API_KEY=

# Database Configuration
DATABASE_PATH=data/recruitment.db

# Scraping Configuration
INTERNSHALA_JOB_ID=

# Dashboard Configuration
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501